# AVIRA Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── AI / LLM APIs ──────────────────────────────────────────────────────────
# Groq API key for LLaMA 3.1 8B (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API key for TTS-1-HD (https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Hardware / IoT ─────────────────────────────────────────────────────────
# IP address of the ESP32 home automation board on your local WiFi
ESP32_IP=192.168.x.x
